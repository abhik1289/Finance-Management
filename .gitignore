# =========================
# Root ignore rules (Vite + Spring Boot)
# =========================

# ---- OS / Editor ----
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.sw?
*.suo

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Environment / local overrides ----
.env
.env.*
!.env.example
*.local

# ---- Frontend (Vite) ----
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/

# ---- Backend (Spring Boot / Java) ----
backend/.gradle/
backend/build/
backend/out/
backend/target/
backend/*.iml

# Maven wrapper jar should be committed; ignore generated wrapper files only if desired
# backend/.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
build/
out/

# Maven
target/

# Java artifacts
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# Spring Boot runtime files
*.pid
*.seed
*.pid.lock

# ---- Test / coverage ----
coverage/
.nyc_output/

# ---- Misc ----
*.tmp
*.temp
